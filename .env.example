# Local model configuration
LILBOT_MODEL_PATH=
# Legacy alias still supported by the CLI.
TEXT_MODEL_PATH=

# Inference settings
LILBOT_DEVICE=auto
LILBOT_MAX_NEW_TOKENS=48
LILBOT_QUANTIZE_4BIT=1
LILBOT_DO_SAMPLE=0
LILBOT_SYSTEM_PROMPT=

# Logging
LILBOT_LOG_LEVEL=WARNING

# Filesystem tools are restricted to this root. Leave empty to use the current
# working directory when lilbot starts.
LILBOT_WORKSPACE_ROOT=
