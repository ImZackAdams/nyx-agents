# Optional app-home override. By default Lilbot uses an OS-level data directory
# such as ~/.local/share/lilbot on Linux.
LILBOT_HOME=

# Backend selection
LILBOT_BACKEND=auto
LILBOT_MODEL_PATH=
# Legacy alias still supported by the CLI.
TEXT_MODEL_PATH=

# Inference settings
LILBOT_DEVICE=auto
LILBOT_MAX_NEW_TOKENS=96
LILBOT_QUANTIZE_4BIT=1
LILBOT_DO_SAMPLE=0
LILBOT_STREAM=1
LILBOT_MAX_AGENT_STEPS=4
LILBOT_HISTORY_MESSAGES=8
LILBOT_SESSION_ID=default
LILBOT_SYSTEM_PROMPT=

# Logging
LILBOT_LOG_LEVEL=WARNING

# Filesystem tools are restricted to this root. Leave empty to use the current
# working directory when lilbot starts.
LILBOT_WORKSPACE_ROOT=

# Optional memory paths. If left empty, Lilbot stores memory in its app data
# directory instead of inside the source tree.
LILBOT_MEMORY_DB_PATH=
LILBOT_MEMORY_JSON_PATH=
