# --- Twitter/X credentials ---
# Either set the TWITTER_* variables or the legacy names used in the codebase.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Legacy names (supported)
API_KEY=
API_SECRET=
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=
BEARER_TOKEN=

# Required for reply handling
BOT_USER_ID=

# --- Local model paths (optional) ---
# Override Stable Diffusion model path if not in repo.
SD_MODEL_PATH=
# Override text model path (Falcon) if not in repo.
TEXT_MODEL_PATH=

# --- Bot identity (optional) ---
BOT_NAME=Athena
BOT_HANDLE=@athena_bot
BOT_BRAND=NyxAgents
BOT_TOPICS=AI agents, tooling, autonomy, browser-native systems, internet culture

# --- LLM providers (optional) ---
OPENAI_API_KEY=
HUGGINGFACE_API_TOKEN=
