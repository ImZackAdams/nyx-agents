# Example bot identity
BOT_NAME=LocalBot
BOT_HANDLE=@localbot
BOT_BRAND=Local LLM Framework
BOT_TOPICS=local LLMs, agents, workflows, tooling

# Required for reply handling
BOT_USER_ID=

# Twitter/X credentials (choose one set)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Legacy names (supported)
API_KEY=
API_SECRET=
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=
BEARER_TOKEN=

# Optional model paths
TEXT_MODEL_PATH=
SD_MODEL_PATH=

# Feature toggles
ENABLE_NEWS=0
ENABLE_MEMES=0

# News feeds (comma-separated RSS URLs). Leave empty to skip news.
NEWS_FEEDS=

# Optional config file
BOT_CONFIG=examples/local_llm/bot.yml

# Simulation settings
SIM_MODE=1
SIM_MIN_TWEET_LENGTH=40
