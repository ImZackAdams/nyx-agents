# Example bot identity
BOT_NAME=Athena
BOT_HANDLE=@athena_bot
BOT_BRAND=NyxAgents
BOT_TOPICS=AI agents, tooling, autonomy, browser-native systems, internet culture

# Feature toggles
ENABLE_NEWS=1
ENABLE_MEMES=1

# News feeds (comma-separated RSS URLs). Leave empty to skip news.
NEWS_FEEDS=

# Optional config file
BOT_CONFIG=examples/nyxagents/bot.yml
# Optional prompt config
BOT_PROMPTS=examples/nyxagents/prompts.yml

# Simulation settings
SIM_MODE=0
SIM_MIN_TWEET_LENGTH=40

# Required for reply handling
BOT_USER_ID=

# Twitter/X credentials (choose one set)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Legacy names (supported)
API_KEY=
API_SECRET=
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=
BEARER_TOKEN=

# Optional model paths
TEXT_MODEL_PATH=
SD_MODEL_PATH=
